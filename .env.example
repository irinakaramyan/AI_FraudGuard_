# ── SECURITY: Copy this file to .env and fill in your values ──────────────────
# NEVER commit .env to version control

# ── Application Secrets ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-strong-random-key
JWT_SECRET_KEY=change-me-generate-a-strong-random-key

# ── Database ───────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-mysql-password
DB_NAME=fraud_detection_db

# ── Application ───────────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000
HOST=127.0.0.1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5000,http://127.0.0.1:5000

# ── Fraud Detection Thresholds ────────────────────────────────────────────────
HIGH_AMOUNT_THRESHOLD=10000
FREQ_THRESHOLD=5
RISK_SCORE_ALERT_THRESHOLD=0.5

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES=3600

# ── AI Assistant ─────────────────────────────────────────────────────────────
# Option A — Groq (FREE): https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Option B — Anthropic (Paid): https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here
