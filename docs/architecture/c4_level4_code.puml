@startuml C4_Level4_CodeDiagram
!theme plain
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam classFontName "Inter, Arial, sans-serif"
skinparam classBackgroundColor #1e293b
skinparam classBorderColor #334155
skinparam classFontColor #e2e8f0
skinparam classArrowColor #38bdf8
skinparam noteBackgroundColor #0f172a
skinparam noteBorderColor #334155
